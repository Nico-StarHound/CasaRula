SUPABASE_URL=https://ryjnwzkrsodgadvqucqa.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
RESTAURANT_ID=

# Printers are now configured from the app (Ajustes → Impresoras),
# stored in the `printers` table. The daemon looks them up there.
#
# The PRINTER_*_IP vars below are kept ONLY as a last-resort fallback
# in case the printers table is empty (e.g. before first setup).
PRINTER_COCINA_IP=
PRINTER_BARRA_IP=
PRINTER_CAJA_IP=
PRINTER_PORT=9100

# Set to "true" to log ESC/POS bytes to console instead of sending to printer.
DRY_RUN=false

# Optional: print every ESC/POS dump to /tmp for debugging.
DEBUG_DUMP=false

# Delay between chunks when sending to slow thermal printers. Default 30ms
# works for the Munbyn ITPP047P. Lower = faster, but risk of garbled output.
CHUNK_DELAY_MS=30
